    <SolidColorBrush x:Key="WindowBrush" Color="{StaticResource ColorWindow}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource ColorSurfaceAlt}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource ColorSurfaceHover}"/>
    <SolidColorBrush x:Key="BorderBrushApple" Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="BorderSoftBrush" Color="{StaticResource ColorBorderSoft}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource ColorPrimaryHover}"/>
    <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource ColorCyan}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ColorDanger}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource ColorText}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ColorTextMuted}"/>
    <SolidColorBrush x:Key="StartButtonBrush" Color="{StaticResource ColorStartButton}"/>
    <SolidColorBrush x:Key="StartButtonHoverBrush" Color="{StaticResource ColorStartButtonHover}"/>
    <SolidColorBrush x:Key="GhostButtonBrush" Color="{StaticResource ColorGhostButton}"/>
    <SolidColorBrush x:Key="GhostButtonHoverBrush" Color="{StaticResource ColorGhostButtonHover}"/>
    <SolidColorBrush x:Key="SwitchKnobBrush" Color="{StaticResource ColorSwitchKnob}"/>

    <!-- ═══ 苹果玻璃风格扩展 ═══ -->
    <Color x:Key="ColorGlassSurface">#1E1E24</Color>
    <Color x:Key="ColorGlassBorder">#2C2C34</Color>
    <Color x:Key="ColorGlassHighlight">#3A3A44</Color>
    <Color x:Key="ColorIconBlue">#1A3A5C</Color>
    <Color x:Key="ColorIconCyan">#1A3A4C</Color>
    <Color x:Key="ColorIconGreen">#1A3A2C</Color>
    <Color x:Key="ColorIconPurple">#2C1A3C</Color>
    <Color x:Key="ColorIconOrange">#3C2A1A</Color>

    <SolidColorBrush x:Key="GlassSurfaceBrush" Color="{StaticResource ColorGlassSurface}"/>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource ColorGlassBorder}"/>
    <SolidColorBrush x:Key="GlassHighlightBrush" Color="{StaticResource ColorGlassHighlight}"/>
    <SolidColorBrush x:Key="IconBlueBrush" Color="{StaticResource ColorIconBlue}"/>
    <SolidColorBrush x:Key="IconCyanBrush" Color="{StaticResource ColorIconCyan}"/>
    <SolidColorBrush x:Key="IconGreenBrush" Color="{StaticResource ColorIconGreen}"/>
    <SolidColorBrush x:Key="IconPurpleBrush" Color="{StaticResource ColorIconPurple}"/>
    <SolidColorBrush x:Key="IconOrangeBrush" Color="{StaticResource ColorIconOrange}"/>

    <DropShadowEffect x:Key="PanelShadow" Color="#000000" BlurRadius="18" ShadowDepth="6" Opacity="0.18"/>
    <DropShadowEffect x:Key="GlassShadowSm" Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.25"/>
    <DropShadowEffect x:Key="GlassShadowMd" Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.30"/>

    <Geometry x:Key="IconPlay">M8,5 L19,12 L8,19 Z</Geometry>
    <Geometry x:Key="IconPause">M7,5 H10 V19 H7 Z M14,5 H17 V19 H14 Z</Geometry>
    <Geometry x:Key="IconScan">M4,7 V5 C4,4.45 4.45,4 5,4 H8 M16,4 H19 C19.55,4 20,4.45 20,5 V7 M20,17 V19 C20,19.55 19.55,20 19,20 H16 M8,20 H5 C4.45,20 4,19.55 4,19 V17 M4,12 H20</Geometry>
    <Geometry x:Key="IconMonitor">M4,5 H20 V16 H4 Z M8,20 H16 M12,16 V20</Geometry>

    <Color x:Key="ColorPrimary">#0A84FF</Color>
    <Color x:Key="ColorPrimaryHover">#2997FF</Color>
    <Color x:Key="ColorCyan">#64D2FF</Color>
    <Color x:Key="ColorSuccess">#30D158</Color>
    <Color x:Key="ColorWarning">#FFD60A</Color>
    <Color x:Key="ColorDanger">#FF453A</Color>
    <Color x:Key="ColorText">#F5F5F7</Color>
    <Color x:Key="ColorTextSecondary">#A1A1AA</Color>
    <Color x:Key="ColorTextMuted">#6E7681</Color>
    <Color x:Key="ColorStartButton">#4A8FE0</Color>
    <Color x:Key="ColorStartButtonHover">#5B9BE8</Color>
    <Color x:Key="ColorGhostButton">#1C1F26</Color>
    <Color x:Key="ColorGhostButtonHover">#242832</Color>

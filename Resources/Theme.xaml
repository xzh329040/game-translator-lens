    <Geometry x:Key="IconMessage">M4,5 H20 V16 H7 L4,19 Z</Geometry>
    <Geometry x:Key="IconActivity">M3,12 H7 L10,5 L14,19 L17,12 H21</Geometry>
    <Geometry x:Key="IconClock">M12,3 A9,9 0 1 0 12,21 A9,9 0 1 0 12,3 M12,7 V12 L15,14</Geometry>
    <Geometry x:Key="IconDatabase">M5,6 C5,4.3 8.1,3 12,3 C15.9,3 19,4.3 19,6 C19,7.7 15.9,9 12,9 C8.1,9 5,7.7 5,6 Z M5,6 V18 C5,19.7 8.1,21 12,21 C15.9,21 19,19.7 19,18 V6 M5,12 C5,13.7 8.1,15 12,15 C15.9,15 19,13.7 19,12</Geometry>
    <Geometry x:Key="IconFolder">M3,6 H9 L11,8 H21 V19 H3 Z</Geometry>

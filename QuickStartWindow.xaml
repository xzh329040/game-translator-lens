<Window x:Class="GameTranslatorLens.QuickStartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="快速上手"
        Height="820" Width="1200"
        MinHeight="680" MinWidth="1000"
        Background="{DynamicResource WindowBrush}"
        Foreground="{DynamicResource TextBrush}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="8"
                            GlassFrameThickness="0" CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- 方案A独有色值：侧边栏背景稍深于主窗 -->
        <Color x:Key="ColorSidebar">#0A0C12</Color>
        <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource ColorSidebar}"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ToolTip 样式：防止暗色主题下白底白字不可见 -->
        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="Background" Value="#2A2D35"/>
            <Setter Property="Foreground" Value="#F5F5F7"/>
            <Setter Property="BorderBrush" Value="#3E424B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToolTip}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarNavItemStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="62"/>
            <Setter Property="Padding" Value="18,0,14,0"/>
            <Setter Property="GroupName" Value="QuickStartSteps"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="NavBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="3,0,0,0"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="NumCircle"
                                        Width="28" Height="28" CornerRadius="14"
                                        Background="#1C2128"
                                        BorderBrush="#2E333D" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.FontSize="13"
                                                      TextElement.FontWeight="SemiBold"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock x:Name="TitleText"
                                               Text="{TemplateBinding Tag}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock x:Name="DescText"
                                               Text="" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,2,0,0" MaxWidth="160"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#141820"/>
                                <Setter TargetName="NavBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="NumCircle" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="NumCircle" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="NumCircle" Property="TextElement.Foreground" Value="White"/>
                                <Setter TargetName="TitleText" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#11151C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepNavButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushApple}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GuideImageStyle" TargetType="{x:Type Image}">
            <Setter Property="Stretch" Value="None"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
            <Setter Property="RenderOptions.EdgeMode" Value="Aliased"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="点击打开原图"/>
            <EventSetter Event="MouseLeftButtonUp" Handler="GuideImage_MouseLeftButtonUp"/>
        </Style>

        <Style x:Key="GuideImageFrameStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushApple}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="268"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════ 左侧导航栏 ═══════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题区 -->
                <StackPanel Grid.Row="0" Margin="22,24,22,18">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconFile}"
                              Style="{StaticResource IconPathStyle}"
                              Stroke="{DynamicResource PrimaryBrush}"
                              Width="19" Height="19" Margin="0,0,10,0"/>
                        <TextBlock Text="快速上手" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Text="Game Translator Lens"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" Margin="0,6,0,0"/>
                    <Border Height="1" Background="{DynamicResource BorderSoftBrush}" Margin="0,16,0,0"/>
                </StackPanel>

                <!-- 步骤导航 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,4,0,0">
                        <RadioButton x:Name="NavStep1" Content="1" Style="{StaticResource SidebarNavItemStyle}"
                                     IsChecked="True" Tag="设置游戏窗口"
                                     ToolTip="建议英文路径，无边框窗口或窗口化无边框"/>
                        <RadioButton x:Name="NavStep2" Content="2" Style="{StaticResource SidebarNavItemStyle}"
                                     Tag="创建 DeepSeek API Key"
                                     ToolTip="打开 DeepSeek 开放平台，创建并复制 API Key"/>
                        <RadioButton x:Name="NavStep3" Content="3" Style="{StaticResource SidebarNavItemStyle}"
                                     Tag="填入程序并获取模型"
                                     ToolTip="粘贴 API Key，获取 deepseek-v4-flash 模型"/>
                        <RadioButton x:Name="NavStep4" Content="4" Style="{StaticResource SidebarNavItemStyle}"
                                     Tag="设置翻译框"
                                     ToolTip="框选 OCR 区域，调整翻译框位置与大小"/>
                        <RadioButton x:Name="NavStep5" Content="5" Style="{StaticResource SidebarNavItemStyle}"
                                     Tag="实机效果"
                                     ToolTip="翻译框低存在感显示，历史消息按顺序回看"/>
                        <RadioButton x:Name="NavStep6" Content="6" Style="{StaticResource SidebarNavItemStyle}"
                                     Tag="中文回话翻译复制"
                                     ToolTip="输入栏输入中文，Enter 后复制译文到剪贴板"/>
                        <RadioButton x:Name="NavStep7" Content="7" Style="{StaticResource SidebarNavItemStyle}"
                                     Tag="自定义翻译搭配"
                                     ToolTip="添加缩写/关键词直接替换译文，不经过 API"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- 底部版本 -->
                <TextBlock x:Name="VersionText" Grid.Row="2"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11" Margin="22,14,22,16"/>
            </Grid>
        </Border>

        <!-- ═══════ 右侧内容区 ═══════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部栏（拖拽 + 关闭） -->
            <Border Grid.Row="0"
                    Background="{DynamicResource WindowBrush}"
                    BorderBrush="{DynamicResource BorderSoftBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,0,8,0">
                    <TextBlock Text="使用指南"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="×"
                            Style="{StaticResource WindowCaptionCloseButtonStyle}"
                            HorizontalAlignment="Right"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- 内容滚动区 -->
            <ScrollViewer x:Name="GuideScrollViewer" Grid.Row="1"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="28,20"
                          PreviewMouseWheel="GuideScrollViewer_PreviewMouseWheel">
                <StackPanel>

                    <!-- ═══ 步骤 1 ═══ -->
                    <Border x:Name="ContentStep1"
                            Visibility="{Binding IsChecked, ElementName=NavStep1, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="22" Margin="0,0,0,20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{DynamicResource PrimaryBrush}">
                                            <TextBlock Text="1" Foreground="White" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                        </Border>
                                        <TextBlock Text="设置游戏窗口" FontSize="20" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="建议把程序放在英文路径;如果中文路径下OCR或启动异常,再移动整个文件夹。屏幕设置建议使用无边框窗口或窗口化无边框,独占全屏可能让截图或翻译框显示不稳定。"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,10,0,16" LineHeight="22" FontSize="13"/>
                                    <Border Style="{StaticResource GuideImageFrameStyle}">
                                        <Image Source="Resources/QuickStart/game-video-settings.png"
                                               Style="{StaticResource GuideImageStyle}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ 步骤 2 ═══ -->
                    <Border x:Name="ContentStep2"
                            Visibility="{Binding IsChecked, ElementName=NavStep2, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="22" Margin="0,0,0,20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{DynamicResource PrimaryBrush}">
                                            <TextBlock Text="2" Foreground="White" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                        </Border>
                                        <TextBlock Text="创建 DeepSeek API Key" FontSize="20" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="打开 DeepSeek 开放平台的 API Keys 页面，点击创建 API key。创建后只会显示一次，请立即复制。"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,10,0,16" LineHeight="22" FontSize="13"/>
                                    <Border Style="{StaticResource GuideImageFrameStyle}">
                                        <Image Source="Resources/QuickStart/deepseek-api-keys.png"
                                               Style="{StaticResource GuideImageStyle}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ 步骤 3 ═══ -->
                    <Border x:Name="ContentStep3"
                            Visibility="{Binding IsChecked, ElementName=NavStep3, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="22" Margin="0,0,0,20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{DynamicResource PrimaryBrush}">
                                            <TextBlock Text="3" Foreground="White" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                        </Border>
                                        <TextBlock Text="填入程序并获取模型" FontSize="20" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="服务选择 DeepSeek，API URL 使用 https://api.deepseek.com，把刚复制的 API Key 粘贴进去。点击«获取模型»后选择 deepseek-v4-flash。"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,10,0,6" LineHeight="22" FontSize="13"/>
                                    <TextBlock Text="注意：DeepSeek API 按量计费，需要在平台充值余额后才能稳定使用；聊天翻译用量通常很小，实际费用非常便宜。"
                                               Foreground="{DynamicResource WarningBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="22" FontSize="13"/>
                                    <Border Style="{StaticResource GuideImageFrameStyle}">
                                        <Image Source="Resources/QuickStart/app-api-config.png"
                                               Style="{StaticResource GuideImageStyle}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ 步骤 4 ═══ -->
                    <Border x:Name="ContentStep4"
                            Visibility="{Binding IsChecked, ElementName=NavStep4, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="22" Margin="0,0,0,20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{DynamicResource PrimaryBrush}">
                                            <TextBlock Text="4" Foreground="White" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                        </Border>
                                        <TextBlock Text="设置翻译框" FontSize="20" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="程序默认通用翻译模式;如果识别漏字、位置不准或翻译明显不对,再点击《选择翻译区域》重新框选游戏左侧聊天框。《调整翻译框》用于移动或缩放译文显示位置;《常态显示翻译框》会让翻译框一直显示;关闭《鼠标穿透》后可以拖动、缩放和滚动翻译框。"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,10,0,4" LineHeight="22" FontSize="13"/>
                                    <Border Style="{StaticResource GuideImageFrameStyle}">
                                        <Image Source="Resources/QuickStart/app-overlay-settings.png"
                                               Style="{StaticResource GuideImageStyle}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ 步骤 5 ═══ -->
                    <Border x:Name="ContentStep5"
                            Visibility="{Binding IsChecked, ElementName=NavStep5, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="22" Margin="0,0,0,20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{DynamicResource PrimaryBrush}">
                                            <TextBlock Text="5" Foreground="White" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                        </Border>
                                        <TextBlock Text="实机效果" FontSize="20" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="正常游玩时翻译框会保持低存在感，不遮挡主要视野。打开聊天框时，历史消息也会按聊天顺序显示，方便回看。"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,10,0,18" LineHeight="22" FontSize="13"/>
                                    <Border Style="{StaticResource GuideImageFrameStyle}">
                                        <Image Source="Resources/QuickStart/game-history-records-new.png"
                                               Style="{StaticResource GuideImageStyle}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ 步骤 6 ═══ -->
                    <Border x:Name="ContentStep6"
                            Visibility="{Binding IsChecked, ElementName=NavStep6, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="22" Margin="0,0,0,20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{DynamicResource PrimaryBrush}">
                                            <TextBlock Text="6" Foreground="White" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                        </Border>
                                        <TextBlock Text="中文回话翻译复制" FontSize="20" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="开启《显示回话输入条》后,翻译框底部会出现输入栏。输入中文,选择自动、英语、日语或韩语,按Enter后程序会把译文复制到剪贴板。程序不会自动替你发送游戏聊天。翻译完成后,请在游戏聊天框里粘贴,再由你自己按Enter发送。"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,10,0,6" LineHeight="22" FontSize="13"/>
                                    <Border Style="{StaticResource GuideImageFrameStyle}" Margin="0,0,0,12">
                                        <Image Source="Resources/QuickStart/reply-overlay-input.png"
                                               Style="{StaticResource GuideImageStyle}"/>
                                    </Border>
                                    <Border Style="{StaticResource GuideImageFrameStyle}">
                                        <Image Source="Resources/QuickStart/reply-game-chat.png"
                                               Style="{StaticResource GuideImageStyle}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ 步骤 7 ═══ -->
                    <Border x:Name="ContentStep7"
                            Visibility="{Binding IsChecked, ElementName=NavStep7, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="22" Margin="0,0,0,20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{DynamicResource PrimaryBrush}">
                                            <TextBlock Text="7" Foreground="White" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                        </Border>
                                        <TextBlock Text="自定义翻译搭配" FontSize="20" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="在游戏选择下方可以添加自定义翻译搭配。在«缩写»框输入原文关键词，«译文»框输入替换后的中文，点击«添加»即可保存。添加后每条记录右侧会出现 ✎ 编辑按钮和 × 删除按钮：点击 ✎ 可将该条目回填到输入框修改后重新添加；点击 × 可直接删除。自定义搭配会绕过 API 直接替换译文，适合缩写、专有名词等固定翻译。"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,10,0,16" LineHeight="22" FontSize="13"/>
                                    <Border Style="{StaticResource GuideImageFrameStyle}">
                                        <Image Source="Resources/QuickStart/Custom-translation.png"
                                               Style="{StaticResource GuideImageStyle}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 底部操作栏 -->
            <Border Grid.Row="2"
                    Background="{DynamicResource WindowBrush}"
                    BorderBrush="{DynamicResource BorderSoftBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <DockPanel LastChildFill="False">
                    <CheckBox x:Name="DoNotShowAgainCheck"
                              Content="下次不再提示"
                              VerticalAlignment="Center"
                              DockPanel.Dock="Left"
                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Width="118"
                            Style="{StaticResource PrimaryButtonStyle}"
                            DockPanel.Dock="Right"
                            Click="Close_Click">
                        <TextBlock Text="开始配置" Foreground="White"/>
                    </Button>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

<Window x:Class="GameTranslatorLens.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现新版本"
        Height="540"
        Width="720"
        MinHeight="480"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Border Background="{DynamicResource WindowBrush}"
            BorderBrush="{DynamicResource BorderBrushApple}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Height="42"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderSoftBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="发现新版本"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    <Button Grid.Column="1"
                            Content="×"
                            Style="{StaticResource WindowCaptionCloseButtonStyle}"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock x:Name="VersionText"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="MetaText"
                               Style="{StaticResource CaptionTextStyle}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource CardBorderStyle}"
                        Margin="0,18,0,12"
                        Padding="12">
                    <TextBlock x:Name="AssetText"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource CardBorderStyle}"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="更新内容"
                                   Style="{StaticResource SectionHeaderTextStyle}"
                                   Margin="14,12,14,8"/>
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="14,0,14,12">
                            <TextBlock x:Name="ReleaseNotesText"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderSoftBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="IgnoreVersionCheck"
                              Content="此版本不再提醒"
                              VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="稍后提醒"
                                Width="92"
                                Click="RemindLater_Click"/>
                        <Button Content="打开发布页"
                                Width="104"
                                Click="OpenReleasePage_Click"/>
                        <Button Width="100"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="8,0,0,0"
                                Click="UpdateNow_Click">
                            <TextBlock Text="立即更新" Foreground="White"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

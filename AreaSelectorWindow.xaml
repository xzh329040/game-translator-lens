<Window x:Class="GameTranslatorLens.AreaSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="#44000000" Topmost="True" ShowInTaskbar="False"
        Cursor="Cross" KeyDown="Window_KeyDown">
    <Canvas x:Name="RootCanvas">
        <Border Canvas.Left="20" Canvas.Top="20" Background="#DD101214" Padding="14,8" BorderBrush="#78D995" BorderThickness="1">
            <TextBlock Text="拖拽选择游戏聊天区域，Esc 取消" Foreground="#F4F7F5" FontWeight="SemiBold"/>
        </Border>
        <Rectangle x:Name="SelectionRect" Stroke="#78D995" StrokeThickness="2" Fill="#2278D995" Visibility="Collapsed"/>
    </Canvas>
</Window>

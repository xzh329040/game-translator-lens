<Window x:Class="GameTranslatorLens.QuickStartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="快速上手"
        Height="780" Width="1120"
        MinHeight="660" MinWidth="940"
        Background="#040508"
        Foreground="{DynamicResource TextBrush}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="8"
                            GlassFrameThickness="0" CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- 方案C游戏风格：深黑 + 霓虹色 -->
        <Color x:Key="ColorNeonCyan">#00E5FF</Color>
        <Color x:Key="ColorNeonGreen">#39FF14</Color>
        <Color x:Key="ColorNeonPurple">#B44CFF</Color>
        <Color x:Key="ColorBgDeep">#040508</Color>
        <Color x:Key="ColorBgCard">#0A0D12</Color>
        <Color x:Key="ColorBorderNeon">#112233</Color>

        <SolidColorBrush x:Key="NeonCyanBrush" Color="{StaticResource ColorNeonCyan}"/>
        <SolidColorBrush x:Key="NeonGreenBrush" Color="{StaticResource ColorNeonGreen}"/>
        <SolidColorBrush x:Key="NeonPurpleBrush" Color="{StaticResource ColorNeonPurple}"/>
        <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource ColorBgDeep}"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource ColorBgCard}"/>
        <SolidColorBrush x:Key="BorderNeonBrush" Color="{StaticResource ColorBorderNeon}"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 霓虹发光效果 -->
        <DropShadowEffect x:Key="NeonGlowCyan" Color="#00E5FF" BlurRadius="16" ShadowDepth="0" Opacity="0.35"/>
        <DropShadowEffect x:Key="NeonGlowGreen" Color="#39FF14" BlurRadius="14" ShadowDepth="0" Opacity="0.3"/>

        <!-- 圆点步骤指示器 -->
        <Style x:Key="StepDotStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="CarouselSteps"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Dot"
                                Width="14" Height="14"
                                CornerRadius="7"
                                Background="#1A1D26"
                                BorderBrush="#2E3340"
                                BorderThickness="1">
                            <Border x:Name="DotInner"
                                    Width="6" Height="6"
                                    CornerRadius="3"
                                    Background="Transparent"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Dot" Property="Background" Value="#0A1A22"/>
                                <Setter TargetName="Dot" Property="BorderBrush" Value="{StaticResource NeonCyanBrush}"/>
                                <Setter TargetName="Dot" Property="Effect" Value="{StaticResource NeonGlowCyan}"/>
                                <Setter TargetName="DotInner" Property="Background" Value="{StaticResource NeonCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Dot" Property="BorderBrush" Value="#4A5A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GuideImageStyle" TargetType="{x:Type Image}">
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
            <Setter Property="RenderOptions.EdgeMode" Value="Aliased"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="点击打开原图"/>
            <EventSetter Event="MouseLeftButtonUp" Handler="GuideImage_MouseLeftButtonUp"/>
        </Style>

        <Style x:Key="ImageGlowFrameStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#0A0D14"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderNeonBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <!-- 渐变顶部色条 -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#00E5FF" Offset="0"/>
            <GradientStop Color="#39FF14" Offset="0.5"/>
            <GradientStop Color="#B44CFF" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="NeonButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="#0F1A1F"
                                BorderBrush="{StaticResource NeonCyanBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="22,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#142530"/>
                                <Setter TargetName="Chrome" Property="Effect" Value="{StaticResource NeonGlowCyan}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 隐藏的步骤切换器 -->
        <StackPanel Visibility="Collapsed">
            <RadioButton x:Name="Dot1" Style="{StaticResource StepDotStyle}" IsChecked="True" GroupName="CarouselSteps"/>
            <RadioButton x:Name="Dot2" Style="{StaticResource StepDotStyle}" GroupName="CarouselSteps"/>
            <RadioButton x:Name="Dot3" Style="{StaticResource StepDotStyle}" GroupName="CarouselSteps"/>
            <RadioButton x:Name="Dot4" Style="{StaticResource StepDotStyle}" GroupName="CarouselSteps"/>
            <RadioButton x:Name="Dot5" Style="{StaticResource StepDotStyle}" GroupName="CarouselSteps"/>
            <RadioButton x:Name="Dot6" Style="{StaticResource StepDotStyle}" GroupName="CarouselSteps"/>
        </StackPanel>

        <Grid.RowDefinitions>
            <RowDefinition Height="4"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部霓虹色条 -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}"/>

        <!-- 标题栏 -->
        <Border Grid.Row="1"
                Background="{StaticResource BgDeepBrush}"
                BorderBrush="#111820" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="20,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="◈" FontSize="16"
                               Foreground="{StaticResource NeonCyanBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               Effect="{StaticResource NeonGlowCyan}"/>
                    <TextBlock Text="快速上手"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#E0E8F0" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource NeonGreenBrush}"
                            CornerRadius="3" Padding="6,2" Margin="10,0,0,0">
                        <TextBlock Text="GUIDE" FontSize="9" FontWeight="Bold"
                                   Foreground="#040508"/>
                    </Border>
                </StackPanel>
                <Button Content="×"
                        Style="{StaticResource WindowCaptionCloseButtonStyle}"
                        HorizontalAlignment="Right"
                        Click="Close_Click"/>
            </Grid>
        </Border>

        <!-- 内容区 -->
        <ScrollViewer x:Name="GuideScrollViewer" Grid.Row="2"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,18"
                      PreviewMouseWheel="GuideScrollViewer_PreviewMouseWheel"
                      Background="{StaticResource BgDeepBrush}">
            <StackPanel>

                <!-- ═══ 简介 ═══ -->
                <Border Background="{StaticResource BgCardBrush}"
                        BorderBrush="{StaticResource BorderNeonBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="20,16" Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="44" Height="44" CornerRadius="10"
                                Background="#0A1420" BorderBrush="#002244" BorderThickness="1">
                            <Path Data="{StaticResource IconMessage}"
                                  Style="{StaticResource IconPathStyle}"
                                  Stroke="{StaticResource NeonCyanBrush}"
                                  Width="22" Height="22"
                                  Effect="{StaticResource NeonGlowCyan}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="Game Translator Lens · 使用指南"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="#E0E8F0"/>
                            <TextBlock Text="6 步完成 API 配置、翻译区域设置与回话输入。建议解压到英文路径。"
                                       Foreground="#6A7A8A" FontSize="13" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ 步骤 1 ═══ -->
                <Border x:Name="Panel1"
                        Visibility="{Binding IsChecked, ElementName=Dot1, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderNeonBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="18,14" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource NeonCyanBrush}"
                                            Width="28" Height="28" CornerRadius="6"
                                            Effect="{StaticResource NeonGlowCyan}">
                                        <TextBlock Text="01" Foreground="#040508" FontWeight="Bold"
                                                   FontSize="12" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="设置游戏窗口"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="#E0E8F0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="建议英文路径；视频设置使用无边框窗口或窗口化无边框，独占全屏可能导致截图或翻译框不稳定。"
                                           Foreground="#6A7A8A" FontSize="13"
                                           TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource ImageGlowFrameStyle}">
                            <Image Source="Resources/QuickStart/game-video-settings.png"
                                   Style="{StaticResource GuideImageStyle}" MaxHeight="500"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══ 步骤 2 ═══ -->
                <Border x:Name="Panel2"
                        Visibility="{Binding IsChecked, ElementName=Dot2, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderNeonBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="18,14" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource NeonGreenBrush}"
                                            Width="28" Height="28" CornerRadius="6"
                                            Effect="{StaticResource NeonGlowGreen}">
                                        <TextBlock Text="02" Foreground="#040508" FontWeight="Bold"
                                                   FontSize="12" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="创建 DeepSeek API Key"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="#E0E8F0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="打开 DeepSeek 开放平台的 API Keys 页面，点击创建 API key。创建后只会显示一次，请立即复制。"
                                           Foreground="#6A7A8A" FontSize="13"
                                           TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource ImageGlowFrameStyle}">
                            <Image Source="Resources/QuickStart/deepseek-api-keys.png"
                                   Style="{StaticResource GuideImageStyle}" MaxHeight="500"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══ 步骤 3 ═══ -->
                <Border x:Name="Panel3"
                        Visibility="{Binding IsChecked, ElementName=Dot3, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderNeonBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="18,14" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource NeonPurpleBrush}"
                                            Width="28" Height="28" CornerRadius="6">
                                        <TextBlock Text="03" Foreground="#040508" FontWeight="Bold"
                                                   FontSize="12" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="填入程序并获取模型"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="#E0E8F0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="服务选 DeepSeek，API URL 填 https://api.deepseek.com，粘贴 Key 后点«获取模型»，选 deepseek-v4-flash。按量计费，用量小费用便宜。"
                                           Foreground="#6A7A8A" FontSize="13"
                                           TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource ImageGlowFrameStyle}">
                            <Image Source="Resources/QuickStart/app-api-config.png"
                                   Style="{StaticResource GuideImageStyle}" MaxHeight="500"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══ 步骤 4 ═══ -->
                <Border x:Name="Panel4"
                        Visibility="{Binding IsChecked, ElementName=Dot4, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderNeonBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="18,14" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource NeonCyanBrush}"
                                            Width="28" Height="28" CornerRadius="6"
                                            Effect="{StaticResource NeonGlowCyan}">
                                        <TextBlock Text="04" Foreground="#040508" FontWeight="Bold"
                                                   FontSize="12" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="设置翻译框"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="#E0E8F0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="程序自带默认翻译区域。先用默认；如有问题点击«选择翻译区域»重新框选。«调整翻译框»移动译文位置，关闭«鼠标穿透»可拖动缩放翻译框。"
                                           Foreground="#6A7A8A" FontSize="13"
                                           TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource ImageGlowFrameStyle}">
                            <Image Source="Resources/QuickStart/app-overlay-settings.png"
                                   Style="{StaticResource GuideImageStyle}" MaxHeight="500"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══ 步骤 5 ═══ -->
                <Border x:Name="Panel5"
                        Visibility="{Binding IsChecked, ElementName=Dot5, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderNeonBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="18,14" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource NeonGreenBrush}"
                                            Width="28" Height="28" CornerRadius="6"
                                            Effect="{StaticResource NeonGlowGreen}">
                                        <TextBlock Text="05" Foreground="#040508" FontWeight="Bold"
                                                   FontSize="12" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="实机效果"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="#E0E8F0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="翻译框低存在感不遮挡视野。打开聊天框时，历史消息按顺序显示，方便回看。"
                                           Foreground="#6A7A8A" FontSize="13"
                                           TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                        <UniformGrid Grid.Row="1" Columns="2">
                            <Border Style="{StaticResource ImageGlowFrameStyle}" Margin="0,0,6,0">
                                <Image Source="Resources/QuickStart/game-low-profile.png"
                                       Style="{StaticResource GuideImageStyle}" MaxHeight="440"/>
                            </Border>
                            <Border Style="{StaticResource ImageGlowFrameStyle}" Margin="6,0,0,0">
                                <Image Source="Resources/QuickStart/game-history-records.png"
                                       Style="{StaticResource GuideImageStyle}" MaxHeight="440"/>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>

                <!-- ═══ 步骤 6 ═══ -->
                <Border x:Name="Panel6"
                        Visibility="{Binding IsChecked, ElementName=Dot6, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderNeonBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="18,14" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource NeonPurpleBrush}"
                                            Width="28" Height="28" CornerRadius="6">
                                        <TextBlock Text="06" Foreground="#040508" FontWeight="Bold"
                                                   FontSize="12" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="中文回话翻译复制"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="#E0E8F0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="开启«显示回话输入条»后在输入栏输入中文，选目标语言，Enter 后译文复制到剪贴板。在游戏聊天框粘贴后自行 Enter 发送。"
                                           Foreground="#6A7A8A" FontSize="13"
                                           TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                        <UniformGrid Grid.Row="1" Columns="2">
                            <Border Style="{StaticResource ImageGlowFrameStyle}" Margin="0,0,6,0">
                                <Image Source="Resources/QuickStart/reply-overlay-input.png"
                                       Style="{StaticResource GuideImageStyle}" MaxHeight="440"/>
                            </Border>
                            <Border Style="{StaticResource ImageGlowFrameStyle}" Margin="6,0,0,0">
                                <Image Source="Resources/QuickStart/reply-game-chat.png"
                                       Style="{StaticResource GuideImageStyle}" MaxHeight="440"/>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部：圆点指示器 + 操作栏 -->
        <Border Grid.Row="3"
                Background="{StaticResource BgDeepBrush}"
                BorderBrush="#111820" BorderThickness="0,1,0,0"
                Padding="22,12">
            <DockPanel LastChildFill="False">
                <CheckBox x:Name="DoNotShowAgainCheck"
                          Content="下次不再提示"
                          VerticalAlignment="Center"
                          DockPanel.Dock="Left"
                          Foreground="{DynamicResource TextSecondaryBrush}"/>

                <!-- 霓虹按钮 -->
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource NeonButtonStyle}"
                        Click="Close_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" FontSize="10" Foreground="{StaticResource NeonCyanBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="开始配置"/>
                    </StackPanel>
                </Button>

                <!-- 圆点指示器 -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0">
                    <RadioButton Style="{StaticResource StepDotStyle}"
                                 IsChecked="{Binding IsChecked, ElementName=Dot1, Mode=TwoWay}"
                                 GroupName="CarouselSteps"/>
                    <RadioButton Style="{StaticResource StepDotStyle}"
                                 IsChecked="{Binding IsChecked, ElementName=Dot2, Mode=TwoWay}"
                                 GroupName="CarouselSteps"/>
                    <RadioButton Style="{StaticResource StepDotStyle}"
                                 IsChecked="{Binding IsChecked, ElementName=Dot3, Mode=TwoWay}"
                                 GroupName="CarouselSteps"/>
                    <RadioButton Style="{StaticResource StepDotStyle}"
                                 IsChecked="{Binding IsChecked, ElementName=Dot4, Mode=TwoWay}"
                                 GroupName="CarouselSteps"/>
                    <RadioButton Style="{StaticResource StepDotStyle}"
                                 IsChecked="{Binding IsChecked, ElementName=Dot5, Mode=TwoWay}"
                                 GroupName="CarouselSteps"/>
                    <RadioButton Style="{StaticResource StepDotStyle}"
                                 IsChecked="{Binding IsChecked, ElementName=Dot6, Mode=TwoWay}"
                                 GroupName="CarouselSteps"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>

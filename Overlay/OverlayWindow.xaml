<Window x:Class="GameTranslatorLens.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Width="520"
        Height="180">
    <Window.Resources>
        <SolidColorBrush x:Key="ReplyComboForegroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ReplyComboAccentBrush" Color="#64D2FF"/>
        <SolidColorBrush x:Key="ReplyComboButtonBrush" Color="#E0181C25"/>
        <SolidColorBrush x:Key="OverlayMutedBrush" Color="#A7AFBA"/>
        <SolidColorBrush x:Key="OverlayPanelBrush" Color="#D40B0C10"/>
        <SolidColorBrush x:Key="OverlayInputBrush" Color="#E0161820"/>
        <SolidColorBrush x:Key="OverlayLineBrush" Color="#33FFFFFF"/>

        <Style x:Key="ReplyComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#171A22"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6">
                            <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="White"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                       TextAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#253044"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#20334A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReplyComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#88FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ReplyComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="Chrome"
                                                CornerRadius="12"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="#5264D2FF"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <TextBlock Text="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           Margin="8,0,18,0"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                                <Path Data="{StaticResource IconChevronDown}"
                                                      Stroke="{StaticResource ReplyComboAccentBrush}"
                                                      StrokeThickness="1.8"
                                                      Stretch="Uniform"
                                                      Width="10"
                                                      Height="10"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#F0141720"
                                        BorderBrush="#3AFFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="4"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="150">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="FloatingPanel"
            Background="{StaticResource OverlayPanelBrush}"
            BorderBrush="#335C9DFF"
            BorderThickness="1"
            CornerRadius="14"
            Padding="14">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="0" Opacity="0.32"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="DragHandleRow" Height="20"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="DragHandle" Cursor="SizeAll" Background="Transparent" Margin="-4,-4,-4,8">
                <Grid>
                    <Border Width="76"
                            Height="4"
                            CornerRadius="2"
                            Background="#4464D2FF"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="drag"
                               Foreground="{StaticResource OverlayMutedBrush}"
                               FontSize="9"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Opacity="0.65"/>
                </Grid>
            </Border>

            <ScrollViewer x:Name="TranslationScrollViewer"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="TranslationScrollViewer_PreviewMouseWheel">
                <ItemsControl x:Name="RecordList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0"
                                        Background="#1E64D2FF"
                                        BorderBrush="#3364D2FF"
                                        BorderThickness="1"
                                        CornerRadius="9"
                                        Padding="7,2"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,5">
                                    <TextBlock Text="{Binding Speaker}"
                                               Foreground="#D7F3FF"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding TranslatedText}"
                                           Foreground="#F5F7FA"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2"
                                           Text="{Binding SourceText}"
                                           Foreground="{StaticResource OverlayMutedBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Opacity="0.68"
                                           Margin="0,3,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <primitives:Thumb x:Name="ResizeGrip"
                              Grid.RowSpan="3"
                              Panel.ZIndex="20"
                              Width="24"
                              Height="24"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Cursor="SizeNWSE">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Grid Background="Transparent">
                            <Border Width="15"
                                    Height="15"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    BorderBrush="#5564D2FF"
                                    BorderThickness="0,0,2,2"
                                    CornerRadius="0,0,4,0"/>
                        </Grid>
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>

            <Border x:Name="ReplyInputPanel"
                    Grid.Row="2"
                    Panel.ZIndex="10"
                    Visibility="Visible"
                    Margin="0,10,30,0"
                    Padding="5"
                    Background="#B012141B"
                    BorderBrush="#2FFFFFFF"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="82"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="34"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="34"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ReplyTargetCombo"
                              Grid.Column="0"
                              Style="{StaticResource ReplyComboBoxStyle}"
                              BorderThickness="1"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="自动" Tag="auto" Style="{StaticResource ReplyComboBoxItemStyle}"/>
                        <ComboBoxItem Content="英语" Tag="en" Style="{StaticResource ReplyComboBoxItemStyle}"/>
                        <ComboBoxItem Content="日语" Tag="ja" Style="{StaticResource ReplyComboBoxItemStyle}"/>
                        <ComboBoxItem Content="韩语" Tag="ko" Style="{StaticResource ReplyComboBoxItemStyle}"/>
                    </ComboBox>
                    <TextBox x:Name="ReplyInputBox"
                             Grid.Column="2"
                             BorderThickness="0"
                             Foreground="#F5F7FA"
                             CaretBrush="#64D2FF"
                             Padding="10,5"
                             VerticalContentAlignment="Center"/>
                    <Button x:Name="ManualOcrButton"
                             Grid.Column="4"
                             Width="32"
                             Height="32"
                             Padding="0"
                             BorderBrush="#44FFFFFF"
                             BorderThickness="1"
                             ToolTip="识别一次当前区域">
                        <Path Data="{StaticResource IconCamera}"
                              Stroke="#D7F3FF"
                              StrokeThickness="1.8"
                              Stretch="Uniform"
                              Width="15"
                              Height="15"/>
                    </Button>
                    <Button x:Name="CopyReplyButton"
                            Grid.Column="6"
                            Width="32"
                            Height="32"
                            Padding="0"
                            BorderBrush="#44FFFFFF"
                            BorderThickness="1"
                             ToolTip="复制译文">
                        <Path Data="{StaticResource IconCopy}"
                              Stroke="#D7F3FF"
                              StrokeThickness="1.8"
                              Stretch="Uniform"
                              Width="15"
                              Height="15"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
